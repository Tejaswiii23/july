from bisect import bisect_right
from typing import List
class Solution:
    def pathExistenceQueries(self, n: int, nums: List[int], maxDiff: int, queries: List[List[int]]) -> List[int]:
        sorted_nodes = sorted(range(n), key=lambda x: nums[x])
        sorted_vals = [nums[i] for i in sorted_nodes]
        pos = [0] * n
        for idx, node in enumerate(sorted_nodes):
            pos[node] = idx
        LOG = 17  
        jump = [[j for j in range(n)] for _ in range(LOG)]
        for i in range(n):
            target = sorted_vals[i] + maxDiff
            j = bisect_right(sorted_vals, target) - 1
            jump[0][i] = j
        for k in range(1, LOG):
            for i in range(n):
                mid = jump[k-1][i]
                jump[k][i] = jump[k-1][mid]
        result = []
        for u, v in queries:
            pu, pv = pos[u], pos[v]
            if pu > pv:
                pu, pv = pv, pu
            if pu == pv:
                result.append(0)
                continue
            steps = 0
            cur = pu
            for k in range(LOG - 1, -1, -1):
                if jump[k][cur] < pv:
                    cur = jump[k][cur]
                    steps += (1 << k)
            if jump[0][cur] >= pv:
                steps += 1
                result.append(steps)
            else:
                result.append(-1)
        return result
